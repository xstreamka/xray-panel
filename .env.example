# === Panel ===
# BASE_URL используется для ссылок в письмах (verify, reset, и т.п.).
# На проде — публичный https-URL панели; для локальной разработки — localhost.
BASE_URL=http://localhost:8080
LISTEN_ADDR=
LISTEN_PORT=8080
# Секрет для подписи сессионных кук и CSRF — замени на случайную строку 32+ символов.
SECRET_KEY=change-me-to-random-string-32ch

# CIDR/IP проксей, чьим X-Forwarded-For / X-Real-IP можно доверять.
# Если панель за nginx на том же хосте — "127.0.0.1/32,::1/128".
# Если nginx на отдельной машине — её IP. Пусто = заголовкам не доверяем
# (нужно при прямом выставлении в интернет, иначе rate-limit обходится подделкой XFF).
TRUSTED_PROXIES=127.0.0.1/32,::1/128

# === PostgreSQL ===
DB_PORT=5432
DB_USER=vpnpanel
DB_PASS=your_secure_password
DB_NAME=vpnpanel

# === Xray API ===
XRAY_API_PORT=10085
XRAY_INBOUND_TAG=vless-in
XRAY_CONFIG_PATH=/etc/xray/config.json
# Конкретный тег xray-core. Не используй :latest на проде —
# обновление образа при `docker compose pull` может незаметно сломать совместимость.
# Список релизов: https://github.com/XTLS/Xray-core/releases
XRAY_IMAGE_TAG=26.3.27

# === Сервер (внешний адрес для VLESS URI) ===
# SERVER_PORT: на этом же порту Xray слушает VLESS-inbound и формируется
# ссылка-подключение в VLESS URI. На проде — 443. Для локальной разработки,
# если :443 уже занят (например, системным nginx), поставь 444/8443 и т.п.
SERVER_ADDR=YOUR_YC_EXTERNAL_IP
SERVER_PORT=443

# === Reality (ЯО inbound) ===
REALITY_DEST=www.google.com:443
REALITY_SERVER_NAME=www.google.com
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=

# === Амстердам (outbound) ===
AMSTERDAM_ADDR=YOUR_AMSTERDAM_VPS_IP
AMSTERDAM_PORT=443
AMSTERDAM_UUID=YOUR_AMSTERDAM_SYSTEM_UUID
AMSTERDAM_SNI=www.google.com
AMSTERDAM_PUBLIC_KEY=
AMSTERDAM_SHORT_ID=

# === SMTP (для верификации email, восстановления пароля, уведомлений) ===
# Если SMTP_HOST/USER/PASSWORD пустые — верификационные ссылки просто логируются
# в консоль (режим разработки), никакие письма не уходят.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=XS VPN <noreply@example.com>

# === Обратная связь ===
# Получатель писем с формы /feedback. Отправка на SMTP_FROM (= self) ненадёжна:
# Gmail и корпоративные фильтры часто кладут self-loop в спам или режут совсем,
# поэтому указываем отдельный ящик.
FEEDBACK_EMAIL=admin@example.com

# === Pay Service (интеграция с внешним pay-service) ===
# PAY_SERVICE_URL — базовый URL pay-service (панель редиректит туда checkout).
# WEBHOOK_SECRET — общий секрет для HMAC-подписи webhook'ов оплаты,
# должен совпадать со значением в pay-service/.env.
PAY_SERVICE_URL=
WEBHOOK_SECRET=
